# Required
ANTHROPIC_API_KEY=your-api-key-here

# Optional — defaults shown
# BEERCAN_DATA_DIR=~/.beercan
# BEERCAN_DEFAULT_MODEL=claude-sonnet-4-6
# BEERCAN_HEAVY_MODEL=claude-opus-4-6
# BEERCAN_GATEKEEPER_MODEL=claude-haiku-4-5-20251001
# BEERCAN_MAX_CONCURRENT=2
# BEERCAN_LOOP_TIMEOUT_MS=600000
# BEERCAN_MAX_ITERATIONS=50
# BEERCAN_TOKEN_BUDGET=100000
# BEERCAN_LOG_LEVEL=info
# BEERCAN_LOG_FILE=~/.beercan/loops.log

# Cloudflare Browser Rendering (optional, for web_fetch tool)
# CLOUDFLARE_API_TOKEN=your-cf-token
# CLOUDFLARE_ACCOUNT_ID=your-cf-account-id
